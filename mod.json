{
    "Name": "fvnkhead.killstat",
    "Description": "gather kill statistics",
    "Version": "1.1.0",
    "LoadPriority": 1,
    "RequiredOnClient": false,
    "ConVars": [
        {
            "Name": "killstat_version",
            "DefaultValue": "ks_1.1.0"
        },
        {
            "Name": "killstat_headers",
            "DefaultValue": "killstatversion,matchid,gamemode,map,time,playercount,attackername,attackerid,attackerweapon,victimname,victimid,victimweapon,distance"
        },
        {
            "Name": "killstat_custom_parameters",
            "DefaultValue": "foo=bar,x=1,y=2,z=3"
        }
    ],
    "Scripts": [
        {
            "Path": "killstat.nut",
            "RunOn": "SERVER",
            "ServerCallback": {
                "After": "killstat_Init"
            }
        }
    ]
}
